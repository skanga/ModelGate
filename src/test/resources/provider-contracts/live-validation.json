{
  "description": "Opt-in live provider validation scenarios. Normal mvn verify only validates this manifest. Set MODELGATE_LIVE_PROVIDER_VALIDATION=true and the required env vars for a scenario to call real upstreams.",
  "scenarios": [
    {
      "name": "openai chat live smoke",
      "provider": "openai",
      "tags": ["chat", "baseline", "openai-compatible"],
      "base_url_env": "MODELGATE_LIVE_OPENAI_BASE_URL",
      "endpoint": "/v1/chat/completions",
      "required_env": ["OPENAI_API_KEY"],
      "api_key_env": "OPENAI_API_KEY",
      "request_body": {
        "model": "${MODELGATE_LIVE_OPENAI_MODEL:-gpt-4o-mini}",
        "messages": [{"role": "user", "content": "Reply with exactly: modelgate-live-ok"}],
        "max_tokens": 16,
        "temperature": 0
      },
      "response_body_contains": ["\"choices\""]
    },
    {
      "name": "anthropic messages live smoke",
      "provider": "anthropic",
      "tags": ["chat", "messages", "baseline"],
      "base_url_env": "MODELGATE_LIVE_ANTHROPIC_BASE_URL",
      "endpoint": "/v1/chat/completions",
      "required_env": ["ANTHROPIC_API_KEY"],
      "api_key_env": "ANTHROPIC_API_KEY",
      "request_body": {
        "model": "${MODELGATE_LIVE_ANTHROPIC_MODEL:-claude-3-5-haiku-latest}",
        "messages": [{"role": "user", "content": "Reply with exactly: modelgate-live-ok"}],
        "max_tokens": 16,
        "temperature": 0
      },
      "response_body_contains": ["\"choices\"", "\"provider\":\"anthropic\""]
    },
    {
      "name": "bedrock anthropic count tokens live smoke",
      "provider": "bedrock",
      "tags": ["count-tokens", "anthropic", "aws"],
      "base_url_env": "MODELGATE_LIVE_BEDROCK_BASE_URL",
      "endpoint": "/v1/messages/count_tokens",
      "required_env": ["BEDROCK_API_KEY"],
      "api_key_env": "BEDROCK_API_KEY",
      "config": {
        "aws_region": "${MODELGATE_LIVE_BEDROCK_REGION:-us-east-1}",
        "aws_auth_type": "apiKey"
      },
      "request_body": {
        "model": "${MODELGATE_LIVE_BEDROCK_MODEL:-anthropic.claude-3-haiku-20240307-v1:0}",
        "messages": [{"role": "user", "content": "Count these tokens"}],
        "max_tokens": 16
      },
      "response_body_contains": ["\"input_tokens\""]
    },
    {
      "name": "vertex gemini chat live smoke",
      "provider": "vertex-ai",
