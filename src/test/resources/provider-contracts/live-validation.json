      "request_body": {
        "model": "${MODELGATE_LIVE_VERTEX_MODEL:-google.gemini-1.5-flash}",
        "messages": [{"role": "user", "content": "Reply with exactly: modelgate-live-ok"}],
        "max_completion_tokens": 16,
        "temperature": 0
